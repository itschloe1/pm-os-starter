{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "agentTeams": {
    "enabled": true,
    "maxAgents": 5
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/on-skill-use.sh\""
          }
        ]
      }
    ]
  }
}
